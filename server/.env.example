# LLM Configuration
# Options: "ollama" or "openai" or "claude"
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# For cloud LLM providers
# OPENAI_API_KEY=your_key_here
# CLAUDE_API_KEY=your_key_here

# Embedding Model (MUST BE SAME FOR INGESTION AND SEARCH)
EMBEDDING_MODEL=nomic-embed-text

# Pinecone
PINECONE_API_KEY=your_key_here
PINECONE_INDEX_NAME=documents
PINECONE_ENVIRONMENT=us-west-1

# Server
PORT=3000
NODE_ENV=development

# Session Storage
SESSION_STORAGE=memory
# DATABASE_URL=mongodb://localhost:27017/assistant

# Logging
LOG_LEVEL=info
